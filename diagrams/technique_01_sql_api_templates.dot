digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.10, nodesep=0.48, ranksep=0.62, splines=ortho];
  node [shape=rect, style="rounded,filled", fontname="Aptos", fontsize=19, margin="0.16,0.10", penwidth=2.0];
  edge [fontname="Aptos", fontsize=12.5, color="#687386", fontcolor="#425466", penwidth=1.7, arrowsize=0.72];
  qa [label="QueryAnalysis\n• domain_type\n• answer_family\n• sql_template_id\n• api_template_ids", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
  tpl [label="Template Binder\n• choose by family\n• bind entities / IDs\n• use known schema + catalog", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
  guard [label="Validators\n• table + column exist\n• endpoint + params allowed", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  plan [label="DraftPlan\n• sql_steps[]\n• api_steps[]\n• dependencies[]", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  qa -> tpl [label="template selected by family"];
  tpl -> guard [label="schema/catalog binding"];
  guard -> plan [label="validated step emitted"];
}
