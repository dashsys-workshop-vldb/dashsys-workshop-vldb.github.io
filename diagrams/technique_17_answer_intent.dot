digraph G {
  graph [rankdir=TB, bgcolor="white", pad=0.10, nodesep=0.48, ranksep=0.62, splines=ortho];
  node [shape=rect, style="rounded,filled", fontname="Aptos", fontsize=19, margin="0.16,0.10", penwidth=2.0];
  edge [fontname="Aptos", fontsize=12.5, color="#687386", fontcolor="#425466", penwidth=1.7, arrowsize=0.72];
  q [label="Question\n• original query text", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
  d1 [label="starts how many?", shape=diamond, fillcolor="#EFE7FF", color="#6D5BD0", width=1.95, height=1.00];
  count [label="COUNT shape\n• start with count", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  d2 [label="asks when?", shape=diamond, fillcolor="#EFE7FF", color="#6D5BD0", width=1.95, height=1.00];
  when [label="WHEN shape\n• date/time or unavailable", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  d3 [label="asks which/list/status?", shape=diamond, fillcolor="#EFE7FF", color="#6D5BD0", width=1.95, height=1.00];
  other [label="LIST / STATUS / DETAIL\n• choose answer shape", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  q -> d1 [label="classify intent"];
  d1 -> count [label="yes"];
  d1 -> d2 [label="no"];
  d2 -> when [label="yes"];
  d2 -> d3 [label="no"];
  d3 -> other [label="match keywords"];
}
