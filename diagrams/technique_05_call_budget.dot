  draft [label="DraftPlan\n• sql_steps = n\n• api_steps = m\n• optional flags", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  rule [label="BudgetRule\n• max_sql\n• max_api\n• max_total\n• family exceptions", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
  apply [label="Budget Applier\n• trim optional first\n• preserve required\n• warn on drops", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
