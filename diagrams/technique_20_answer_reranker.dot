digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.10, nodesep=0.48, ranksep=0.62, splines=ortho];
  node [shape=rect, style="rounded,filled", fontname="Aptos", fontsize=19, margin="0.16,0.10", penwidth=2.0];
  edge [fontname="Aptos", fontsize=12.5, color="#687386", fontcolor="#425466", penwidth=1.7, arrowsize=0.72];
  candidates [label="Candidate Answers\n• concise\n• evidence-grounded\n• gold-style", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  scores [label="Rerank Table\n• verifier pass\n• intent match\n• length\n• unsupported claims", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  final [label="Final Answer\n• best supported\n• short if tied", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  candidates -> scores [label="same evidence only"];
  scores -> final [label="choose best"];
}
