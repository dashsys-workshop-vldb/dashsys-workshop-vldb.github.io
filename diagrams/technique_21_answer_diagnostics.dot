digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.10, nodesep=0.48, ranksep=0.62, splines=ortho];
  node [shape=rect, style="rounded,filled", fontname="Aptos", fontsize=19, margin="0.16,0.10", penwidth=2.0];
  edge [fontname="Aptos", fontsize=12.5, color="#687386", fontcolor="#425466", penwidth=1.7, arrowsize=0.72];
  final [label="Final Answer\n• answer_family\n• answer_intent\n• verifier status", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  diag [label="AnswerDiagnostics\n• verifier_passed\n• unsupported_claims_count\n• rewrite_applied\n• selected_candidate_type", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  traj [label="trajectory.json\n• answer diagnostics\n• tool results\n• optimizer actions", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  fail [label="failure_analysis\n• weak family\n• recommended_fix", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  final -> diag [label="record compact stats"];
  diag -> traj [label="write trace"];
  traj -> fail [label="debug next pass"];
}
