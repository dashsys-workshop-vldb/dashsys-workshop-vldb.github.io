digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.10, nodesep=0.48, ranksep=0.62, splines=ortho];
  node [shape=rect, style="rounded,filled", fontname="Aptos", fontsize=19, margin="0.16,0.10", penwidth=2.0];
  edge [fontname="Aptos", fontsize=12.5, color="#687386", fontcolor="#425466", penwidth=1.7, arrowsize=0.72];
  eval [label="EvalResults\n• sql_score\n• api_score\n• answer_score\n• final_score\n• tool_calls\n• tokens", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  rank [label="FailureAnalysis\n• lowest_examples[]\n• failure_category\n• recommended_fix", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  patch [label="Reusable Fix\n• rule/template update\n• not exact public answer", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
  tests [label="RegressionTests\n• test_name\n• expected_behavior", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  eval -> rank [label="rank low-score cases"];
  rank -> patch [label="categorize + inspect"];
  patch -> tests [label="lock behavior"];
}
