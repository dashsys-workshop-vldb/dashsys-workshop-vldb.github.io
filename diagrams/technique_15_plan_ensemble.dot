digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.10, nodesep=0.48, ranksep=0.62, splines=ortho];
  node [shape=rect, style="rounded,filled", fontname="Aptos", fontsize=19, margin="0.16,0.10", penwidth=2.0];
  edge [fontname="Aptos", fontsize=12.5, color="#687386", fontcolor="#425466", penwidth=1.7, arrowsize=0.72];
  cands [label="Candidate Plans\n• A fast path\n• B SQL template\n• C lookup path\n• D generic", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
  scores [label="Pre-execution Scores\n• validation\n• relevance\n• cost\n• placeholder risk", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  selected [label="SelectedPlan\n• highest score\n• unresolved = 0\n• estimated low cost", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  execute [label="Executor\n• execute one plan only", shape=rect, fillcolor="#EAF3FF", color="#1769AA"];
  cands -> scores [label="score before execution"];
  scores -> selected [label="pick winner"];
  selected -> execute [label="single plan"];
}
