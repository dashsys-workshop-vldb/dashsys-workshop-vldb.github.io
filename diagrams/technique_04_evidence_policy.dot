digraph G {
  graph [rankdir=TB, bgcolor="white", pad=0.10, nodesep=0.48, ranksep=0.62, splines=ortho];
  node [shape=rect, style="rounded,filled", fontname="Aptos", fontsize=19, margin="0.16,0.10", penwidth=2.0];
  edge [fontname="Aptos", fontsize=12.5, color="#687386", fontcolor="#425466", penwidth=1.7, arrowsize=0.72];
  input [label="QueryAnalysis + DraftPlan\n• family\n• route_type\n• sql evidence possible\n• api templates", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
  d1 [label="API-only or live data?", shape=diamond, fillcolor="#EFE7FF", color="#6D5BD0", width=1.95, height=1.00];
  required [label="ApiNeedDecision\n• mode = API_REQUIRED\n• reason\n• max_api_calls", shape=rect, fillcolor="#FFF3E0", color="#D97706"];
  d2 [label="Can SQL fully answer?", shape=diamond, fillcolor="#EFE7FF", color="#6D5BD0", width=1.95, height=1.00];
  skip [label="ApiNeedDecision\n• mode = API_SKIP\n• reason = SQL enough", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  optional [label="ApiNeedDecision\n• mode = API_OPTIONAL\n• cap optional API calls", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
  input -> d1 [label="inspect query family"];
  d1 -> required [label="yes"];
  d1 -> d2 [label="no"];
  d2 -> skip [label="yes"];
  d2 -> optional [label="API may verify"];
}
