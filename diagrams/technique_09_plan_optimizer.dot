digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.10, nodesep=0.48, ranksep=0.62, splines=ortho];
  node [shape=rect, style="rounded,filled", fontname="Aptos", fontsize=19, margin="0.16,0.10", penwidth=2.0];
  edge [fontname="Aptos", fontsize=12.5, color="#687386", fontcolor="#425466", penwidth=1.7, arrowsize=0.72];
  before [label="DraftPlan Before\n• steps = [SQL1, API1, API1_dup,\nAPI_<id>]\n• api_skip flags\n• placeholders", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  opt [label="PlanOptimizer\n• remove duplicates\n• remove API_SKIP\n• drop placeholders\n• enforce budget", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
  after [label="OptimizedPlan After\n• steps = [SQL1, API1]\n• optimizer_actions[]\n• unresolved_placeholders[]", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  before -> opt [label="state transition"];
  opt -> after [label="cleaned + bounded"];
}
