  tool [label="ToolEvidence\n• sql rows\n• api payloads\n• dry_run/errors", shape=rect, fillcolor="#E8FAF8", color="#0B8F8A"];
  family [label="Answer Family\n• count\n• list\n• published status\n• tag detail\n• observability", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
