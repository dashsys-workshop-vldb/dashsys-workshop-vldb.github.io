digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.10, nodesep=0.48, ranksep=0.62, splines=ortho];
  node [shape=rect, style="rounded,filled", fontname="Aptos", fontsize=19, margin="0.16,0.10", penwidth=2.0];
  edge [fontname="Aptos", fontsize=12.5, color="#687386", fontcolor="#425466", penwidth=1.7, arrowsize=0.72];
  results [label="ToolResults\n• rows: [{name,\nlastdeployedtime:null}]\n• api dry_run=true", shape=rect, fillcolor="#E8FAF8", color="#0B8F8A"];
  slots [label="AnswerSlots\n• entity_name\n• entity_id\n• count\n• status\n• timestamp\n• metric_value\n• dry_run\n• discrepancy", shape=rect, fillcolor="#E8F7ED", color="#1A7F52"];
  answer [label="Answer Source\n• only supported values\n• safe caveats", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  results -> slots [label="raw -> structured"];
  slots -> answer [label="source of truth"];
}
