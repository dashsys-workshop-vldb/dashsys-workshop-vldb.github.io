digraph G {
  graph [rankdir=LR, bgcolor="white", pad=0.10, nodesep=0.48, ranksep=0.62, splines=ortho];
  node [shape=rect, style="rounded,filled", fontname="Aptos", fontsize=19, margin="0.16,0.10", penwidth=2.0];
  edge [fontname="Aptos", fontsize=12.5, color="#687386", fontcolor="#425466", penwidth=1.7, arrowsize=0.72];
  raw [label="RawQuery\n• original text\n• smart quotes\n• data-flow\n• extra spaces", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
  norm [label="Normalizer\n• clean whitespace\n• normalize quotes/hyphens\n• normalize synonyms/plurals", shape=rect, fillcolor="#EFE7FF", color="#6D5BD0"];
  out [label="NormalizedQuery\n• original\n• normalized\n• matching_text\n• rewrites[]", shape=rect, fillcolor="#F2F4F7", color="#687386"];
  raw -> norm [label="preserve original"];
  norm -> out [label="clean text for matching"];
}
