# Safe placeholder template for local Adobe credentials used in live-readiness checks.
# This file is safe to commit because it contains placeholders only.
# Copy it to .env.local and fill values only on your local machine.
# Never commit .env.local or put real secrets in committed files.
# Access tokens can expire and may require manual refresh.

ADOBE_ACCESS_TOKEN=
ADOBE_API_KEY=
ADOBE_ORG_ID=
ADOBE_SANDBOX_NAME=
ADOBE_BASE_URL=https://platform.adobe.io

# Optional legacy aliases supported by current code.
ACCESS_TOKEN=
CLIENT_ID=
IMS_ORG=
SANDBOX=

# Optional OAuth/server-to-server placeholders (supported if configured).
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
ADOBE_SCOPES=
ADOBE_TECHNICAL_ACCOUNT_ID=
